DJANGO_DEBUG=0
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,192.0.2.10
# Only needed behind a reverse proxy/tunnel on its own hostname, e.g. Cloudflare Tunnel.
# DJANGO_CSRF_TRUSTED_ORIGINS=https://lif.example.com
# DJANGO_TRUST_PROXY_SSL_HEADER=1
LIF_REQUIRE_LOGIN=1
LIF_VERSION=container
# Not set automatically here (this compose file has no git checkout to read
# from). Set to `git rev-parse --short HEAD` if you want it in the footer.
# LIF_GIT_COMMIT=
